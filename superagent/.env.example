# SUPERAGENT Environment Variables
# Copy to .env and fill in your values

# === LLM Providers ===
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
# Optional: custom API base for self-hosted models
# LLM_API_BASE=http://localhost:11434

# === Messaging Channels ===
TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNOpqrSTUvwxYZ
DISCORD_BOT_TOKEN=
API_AUTH_TOKEN=change-me-to-a-secure-random-string

# === Data Providers ===
ALPHA_VANTAGE_API_KEY=

# === Infrastructure ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# === Database ===
DATABASE_URL=sqlite:///./data/superagent.db

# === Security ===
# Comma-separated list of allowed Telegram user IDs
TELEGRAM_ALLOWED_USERS=
# Enable memory write approval (true/false)
MEMORY_WRITE_APPROVAL=false

# === Logging ===
LOG_LEVEL=INFO
